{
  "name": "trustedpaymentinfrastructureforagents",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/server.ts",
    "worker": "ts-node -r tsconfig-paths/register src/worker/stubWorker.ts",
    "build": "tsc",
    "test": "jest",
    "test:integration": "TELEGRAM_MOCK=true jest --testPathPatterns=integration --runInBand --forceExit",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "seed": "ts-node -r tsconfig-paths/register src/db/seed.ts",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.8",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.0",
    "grammy": "^1.42.0",
    "ioredis": "^5.10.1",
    "pino": "^10.3.1",
    "stripe": "^22.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "jest": "^30.4.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^5.14.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.2"
  }
}
